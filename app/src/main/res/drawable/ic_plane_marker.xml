    android:width="56dp"
    android:height="56dp"
    android:viewportWidth="56"
    android:viewportHeight="56">

    <!-- Soft glow (baked in because iconHalo* on SymbolOptions only applies to
         SDF icons, not raster bitmaps). Drawn as an outer amber silhouette
         with low alpha for a luminous aura on any basemap. -->
    <path
        android:fillColor="#3DFFB86B"
        android:pathData="M28,0
            L31.5,3.5 L31.5,16 L56,28 L56,33 L31.5,30.5 L31.5,46
