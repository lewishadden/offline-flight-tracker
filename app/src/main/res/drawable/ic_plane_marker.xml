        android:fillColor="#FFD59B"
        android:pathData="M26,18 L3,29.2 L3,29.6 L26,26 Z" />
    <!-- Wing leading-edge highlight (right) -->
    <path
        android:fillColor="#FFD59B"
        android:pathData="M30,18 L53,29.2 L53,29.6 L30,26 Z" />

